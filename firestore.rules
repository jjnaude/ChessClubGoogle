rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: players
    // Fields: name (string), isPresent (bool), rankings (map), createdAt (timestamp)
    //
    // Collection: games
    // Fields: whitePlayerId (string), blackPlayerId (string), result (string), ladderType (string), timestamp (timestamp)
    //
    // Collection: pairings
    // Fields: whitePlayerId (string), blackPlayerId (string), ladderType (string), status (string)
    //
    // Collection: bans
    // Fields: player1Id (string), player2Id (string)
    //
    // Collection: users
    // Fields: uid (string), email (string), playerIds (list), role (string), isApproved (bool)
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "naude.jj@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isApproved() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && 
        ((request.auth.token.email == "naude.jj@gmail.com" && request.auth.token.email_verified == true) || 
         (request.resource.data.role == 'user' && request.resource.data.isApproved == false));
      allow update: if isAdmin() || (isOwner(userId) && request.resource.data.role == resource.data.role && request.resource.data.isApproved == resource.data.isApproved);
    }

    match /players/{playerId} {
      allow read: if isAuthenticated();
      allow update: if isAdmin() || (isApproved() && (
        (playerId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.playerIds && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isPresent'])) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rankings'])
      ));
      allow create, delete: if isAdmin();
    }

    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /pairings/{pairingId} {
      allow read: if isAuthenticated();
      allow update: if isAdmin() || (isApproved() && (
        resource.data.whitePlayerId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.playerIds || 
        resource.data.blackPlayerId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.playerIds
      ) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'result']) &&
      request.resource.data.status == 'completed');
      allow create, delete: if isAdmin();
    }

    match /bans/{banId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
